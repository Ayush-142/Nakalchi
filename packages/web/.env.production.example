# Copy to packages/web/.env.production on the VM and fill in real values
# (gitignored - this .example is the tracked template). These are read
# server-side at request time (packages/web/src/lib/api.ts's getConfig(),
# gated behind `import 'server-only'`) - NOT Next.js NEXT_PUBLIC_* vars, so
# they are supplied here as container runtime env, not baked in at
# `docker build` time.

# nakalchi-api's own service name on the shared `codearena` network.
NAKALCHI_API_BASE_URL=http://nakalchi-api:3000

# One of the values from packages/service/.env.production's API_KEYS.
NAKALCHI_API_KEY=<generated, matches one of nakalchi-api's API_KEYS>
