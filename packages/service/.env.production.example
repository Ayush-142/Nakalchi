# Copy to packages/service/.env.production on the VM and fill in real
# values (never commit the real file - .env.production is gitignored, this
# .example is the only version tracked in git). Shared by both
# nakalchi-api and nakalchi-worker (docker-compose.prod.yml's env_file).
# See packages/service/src/config/env.ts for full validation rules.

# CodeArena's existing `mongo` container on the shared `codearena` network,
# a database named `Nakalchi`, and a DEDICATED SCOPED USER - never
# CodeArena's root credentials (see docs/deploy-runbook.md, "Mongo
# credentials" for the exact `createUser` command used to make this user).
MONGO_URI=mongodb://nakalchi_svc:<generated>@mongo:27017/Nakalchi?authSource=Nakalchi

# CodeArena's existing `redis` container, shared - QUEUE_PREFIX below keeps
# BullMQ key namespaces apart from CodeArena's own queues on the same Redis.
REDIS_URL=redis://redis:6379
QUEUE_PREFIX=Nakalchi:

# Comma-separated. Generate with: openssl rand -hex 32
API_KEYS=<generated>

# Min 16 chars. Generate with: openssl rand -hex 32
# Must match the value CodeArena's own NAKALCHI_WEBHOOK_SECRET uses (this
# is the shared secret the webhook receiver at CodeArena's
# /internal/webhooks/nakalchi verifies inbound calls against).
WEBHOOK_SECRET=<generated>

PORT=3000
WORKER_CONCURRENCY=1

# CodeArena's own `api` container, direct container DNS (both stacks share
# the `codearena` network - no need to go out through the public domain or
# Caddy for service-to-service traffic).
CODEARENA_BASE_URL=http://api:3001

# Min 16 chars. Must match CodeArena's own INTERNAL_SERVICE_TOKEN
# (protects CodeArena's GET /internal/contests/:id/submissions, which this
# worker calls in pull mode).
CODEARENA_SERVICE_TOKEN=<generated, matches CodeArena's INTERNAL_SERVICE_TOKEN>
